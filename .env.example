# =====================================================================
# Multica Telegram Bridge — Exemplo de configuração
# Copie este arquivo para `.env` e preencha com valores reais.
# NUNCA commite o arquivo `.env` com segredos reais.
# =====================================================================

# ----------------------------- Telegram ------------------------------
# Token do bot fornecido pelo @BotFather (obrigatório)
TELEGRAM_BOT_TOKEN=123456:telegram_bot_token

# Modo de operação: "polling" (recomendado para começar) ou "webhook"
TELEGRAM_MODE=polling

# URL pública do webhook (obrigatório apenas quando TELEGRAM_MODE=webhook)
TELEGRAM_WEBHOOK_URL=https://bridge.exemplo.com/telegram/webhook

# Token secreto opcional para validar requisições do webhook do Telegram
TELEGRAM_WEBHOOK_SECRET=

# IDs de usuários autorizados, separados por vírgula (OBRIGATÓRIO)
TELEGRAM_ALLOWED_USER_IDS=123456789,987654321

# IDs de chats/grupos autorizados, separados por vírgula (opcional)
TELEGRAM_ALLOWED_CHAT_IDS=

# ----------------------------- Multica -------------------------------
# URL base do backend do Multica (obrigatório)
MULTICA_API_BASE_URL=http://localhost:8080

# URL do WebSocket do Multica (ws:// ou wss://) — endpoint /ws
MULTICA_WS_URL=ws://localhost:8080/ws

# Origin enviado no handshake do WebSocket. O backend valida o Origin contra
# uma allowlist (CORS_ALLOWED_ORIGINS/FRONTEND_ORIGIN no Multica); se não bater,
# o upgrade é recusado com 403. Se vazio, é derivado de MULTICA_WS_URL
# (ex.: wss://host/ws -> https://host). Em self-hosted, use a origem do frontend.
MULTICA_WS_ORIGIN=

# Identificação do cliente enviada como query params no upgrade do WebSocket.
MULTICA_WS_CLIENT_PLATFORM=telegram-bridge
MULTICA_WS_CLIENT_VERSION=1.0.0

# Personal Access Token dedicado ao bridge (OBRIGATÓRIO, segredo crítico)
MULTICA_API_TOKEN=mul_xxxxxxxxxxxxxxxxxxxxx

# Slug do workspace controlado pelo Telegram (obrigatório)
MULTICA_WORKSPACE_SLUG=workspace-slug

# ID do workspace (opcional, usado em filtros de eventos do WebSocket)
MULTICA_WORKSPACE_ID=

# ----------------------------- Bridge --------------------------------
# URL pública do bridge (opcional)
BRIDGE_PUBLIC_URL=https://bridge.exemplo.com

# Porta HTTP do serviço (health check / webhook)
BRIDGE_PORT=3333

# Nível de log: trace | debug | info | warn | error | fatal
BRIDGE_LOG_LEVEL=info

# Fuso horário usado na formatação de datas
BRIDGE_TIMEZONE=America/Sao_Paulo

# Tempo de vida do cache de agentes/squads em segundos
BRIDGE_CACHE_TTL_SECONDS=300

# Habilita conexão WebSocket com o Multica
BRIDGE_ENABLE_WEBSOCKET=true

# Habilita fallback por polling quando o WebSocket cair
BRIDGE_ENABLE_POLLING_FALLBACK=true

# Intervalo do polling de fallback em segundos
BRIDGE_POLLING_INTERVAL_SECONDS=30

# Chat padrão que recebe as notificações em tempo real
BRIDGE_NOTIFICATION_CHAT_ID=123456789

# ----------------------------- Segurança -----------------------------
# Exige menção explícita (@agente) para acionar agentes em grupos
BRIDGE_REQUIRE_EXPLICIT_MENTION=true

# Permite que o bot responda em grupos
BRIDGE_ALLOW_GROUP_MESSAGES=true

# Tamanho máximo de mensagem enviada ao Telegram
BRIDGE_MAX_MESSAGE_LENGTH=3500

# Prefixo dos comandos
BRIDGE_COMMAND_PREFIX=/

# Limite de requisições por usuário por minuto (rate limit simples)
BRIDGE_RATE_LIMIT_PER_MINUTE=30

# --------------------------- Storage opcional ------------------------
# Banco de dados (opcional — o MVP funciona apenas em memória)
DATABASE_URL=

# Redis (opcional)
REDIS_URL=
